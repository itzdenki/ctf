# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Public application URL used for OAuth callbacks and webhook links.
APP_URL="http://localhost:3000"

# Optional one-time admin bootstrap. When the admins table is empty,
# the first successful /admin login with these credentials creates an admin row.
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="change-me-before-production"

# CTFtime OAuth2
CTFTIME_CLIENT_ID="your-ctftime-event-id"
CTFTIME_CLIENT_SECRET="your-ctftime-client-secret"

# Discord first blood webhook. Leave empty to disable.
DISCORD_FIRST_BLOOD_WEBHOOK_URL="https://discord.com/api/webhooks/your-first-blood-webhook"
DISCORD_FIRST_BLOOD_WEBHOOK_USERNAME="LYKNCTF"

# Discord admin-only alert webhook. Point this webhook at your private admin channel.
DISCORD_ADMIN_ALERT_WEBHOOK_URL="https://discord.com/api/webhooks/your-admin-alert-webhook"
DISCORD_ADMIN_ALERT_WEBHOOK_USERNAME="CTF Admin Alert"
